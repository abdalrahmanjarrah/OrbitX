    "AwarenessSignal": {
      "title": "AwarenessSignal",
      "description": "Classified awareness post",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "authorId": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "views": {
          "type": "number"
        },
        "likes": {
          "type": "number"
        }
      },
      "required": [
        "title",
        "content",
        "category",
        "authorId",
        "timestamp",
        "views",
        "likes"
      ]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles (Private, contains PII)"
    },
    "/profiles/{uid}": {
      "schema": "PublicProfile",
      "description": "Public user profiles (No PII)"
    },
    "/users/{uid}/friends/{friendId}": {
      "schema": "Friend",
      "description": "User friends list"
    },
    "/users/{uid}/schedule/{itemId}": {
      "schema": "ScheduleItem",
      "description": "User study schedules"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Study rooms"
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Room-specific chat messages"
    },
    "/advices/{adviceId}": {
      "schema": "Advice",
      "description": "Admin advices"
    },
    "/exhibitions/{exhibitionId}": {
      "schema": "Exhibition",
      "description": "Global exhibition gallery"
    },
    "/suggestions/{suggestionId}": {
      "schema": "Suggestion",
      "description": "User suggestions"
    },
    "/global_chat/{messageId}": {
      "schema": "Message",
      "description": "Global chat messages"
    },
    "/discussions/{discussionId}": {
      "schema": "Discussion",
      "description": "Forum discussions"
    },
    "/discussions/{discussionId}/replies/{replyId}": {
      "schema": "Reply",
      "description": "Discussion replies"
    },
    "/challenges/{challengeId}": {
      "schema": "Challenge",
      "description": "User challenges"
    },
    "/awareness_signals/{signalId}": {
      "schema": {
        "$ref": "#/entities/AwarenessSignal"
      },
      "description": "Awareness signals"
    }
  }
}